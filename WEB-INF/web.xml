
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

<!-- Welcome Page -->
<welcome-file-list>
<welcome-file>login.jsp</welcome-file>
</welcome-file-list>

<!-- Signup -->
<servlet>
<servlet-name>SignupServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.SignupServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>SignupServlet</servlet-name>
<url-pattern>/signup</url-pattern>
</servlet-mapping>

<!-- OTP Verify -->
<servlet>
<servlet-name>VerifyServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.VerifyServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>VerifyServlet</servlet-name>
<url-pattern>/verify</url-pattern>
</servlet-mapping>

<!-- Login -->
<servlet>
<servlet-name>LoginServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.LoginServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>LoginServlet</servlet-name>
<url-pattern>/login</url-pattern>
</servlet-mapping>

<!-- Logout -->
<servlet>
<servlet-name>LogoutServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>LogoutServlet</servlet-name>
<url-pattern>/logout</url-pattern>
</servlet-mapping>

<!-- Local Game -->
<servlet>
<servlet-name>GameServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.GameServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>GameServlet</servlet-name>
<url-pattern>/game</url-pattern>
</servlet-mapping>

<!-- Save Game -->
<servlet>
<servlet-name>SaveGameServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.SaveGameServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>SaveGameServlet</servlet-name>
<url-pattern>/saveGame</url-pattern>
</servlet-mapping>

<!-- History -->
<servlet>
<servlet-name>HistoryServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.HistoryServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>HistoryServlet</servlet-name>
<url-pattern>/history</url-pattern>
</servlet-mapping>

<!-- Create Room -->
<servlet>
<servlet-name>CreateRoomServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.CreateRoomServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>CreateRoomServlet</servlet-name>
<url-pattern>/createRoom</url-pattern>
</servlet-mapping>

<!-- Join Room -->
<servlet>
<servlet-name>JoinRoomServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.JoinRoomServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>JoinRoomServlet</servlet-name>
<url-pattern>/joinRoom</url-pattern>
</servlet-mapping>

<!-- Move -->
<servlet>
<servlet-name>MoveServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.MoveServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>MoveServlet</servlet-name>
<url-pattern>/move</url-pattern>
</servlet-mapping>

<!-- Board -->
<servlet>
<servlet-name>BoardServlet</servlet-name>
<servlet-class>com.tictactoe.servlet.BoardServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>BoardServlet</servlet-name>
<url-pattern>/board</url-pattern>
</servlet-mapping>

</web-app>
